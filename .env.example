# ===========================================
# 로컬 개발 환경 설정
# 사용법: cp .env.example .env
# ===========================================

# --- Backend (apps/api) ---
NODE_ENV=development
PORT=4000

# Database (PostgreSQL)
# 로컬 (Docker): postgresql://postgres:postgres@localhost:5432/myapp
# Neon:          postgresql://<user>:<password>@<host>.neon.tech/<dbname>?sslmode=require
DATABASE_URL="postgresql://postgres:postgres@localhost:5432/myapp"

# --- Logging (apps/api) ---
# default(dev): debug / default(prod): info  — 옵션 (생략 가능)
# LOG_LEVEL=debug
# default(dev): true / default(prod): false  — pino-pretty 출력 여부
# LOG_PRETTY=true

# --- Security (apps/api) ---
# default: http://localhost:3000  — 콤마 구분 다중 origin 허용
# CORS_ALLOWED_ORIGINS=http://localhost:3000
# default: 60000 (60s)
# RATE_LIMIT_WINDOW_MS=60000
# default: 100
# RATE_LIMIT_MAX=100

# --- Health (apps/api) ---
# default: 2000 (DB ping 타임아웃, ms)
# HEALTH_DB_TIMEOUT_MS=2000

# --- Examples 도메인 (apps/api) ---
# default(dev): true / default(prod): false  — 레퍼런스 CRUD 라우터 활성 여부
# ENABLE_EXAMPLES=true

# --- Frontend (apps/web) ---
VITE_API_BASE_URL=http://localhost:4000

# --- Storybook (apps/storybook) ---
VITE_STORYBOOK_MODE=true
VITE_ENABLE_MOCK_API=true
VITE_MOCK_DELAY=500

# ===========================================
# dev / staging / prod 환경에서는 .env 파일을 사용하지 않습니다.
# 배포 플랫폼(Vercel 등)의 Environment Variables에서 직접 설정하세요.
# DATABASE_URL은 Neon 연결 문자열을 사용합니다.
# ===========================================
