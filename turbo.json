{
  "$schema": "https://turbo.build/schema.json",
  "globalEnv": [
    "DATABASE_URL",
    "npm_package_version",
    "DEV",
    "PROD",
    "PORT",
    "LOG_LEVEL",
    "LOG_PRETTY",
    "CORS_ALLOWED_ORIGINS",
    "RATE_LIMIT_WINDOW_MS",
    "RATE_LIMIT_MAX",
    "HEALTH_DB_TIMEOUT_MS",
    "ENABLE_EXAMPLES"
  ],
  "globalDependencies": ["**/.env"],
  "tasks": {
    "build": {
      "dependsOn": ["^build"],
      "outputs": ["dist/**", ".next/**", "!.next/cache/**", "storybook-static/**"],
      "env": ["NODE_ENV"]
    },
    "lint": {
      "dependsOn": ["^lint"]
    },
    "typecheck": {
      "dependsOn": ["^typecheck"],
      "outputs": []
    },
    "dev": {
      "cache": false,
      "persistent": true
    },
    "test": {
      "dependsOn": ["^build", "@repo/vitest-config#build"],
      "outputs": ["coverage/**"],
      "inputs": ["src/**", "test/**", "tests/**", "**/*.test.ts", "**/*.test.tsx"],
      "passThroughEnv": ["PLAYWRIGHT_*", "CI"]
    },
    "test:watch": {
      "cache": false,
      "persistent": true
    },
    "migrate": {
      "inputs": ["prisma/schema.prisma", "prisma/migrations/**"],
      "cache": false
    },
    "db:generate": {
      "inputs": ["prisma/schema.prisma"],
      "outputs": ["generated/prisma/**"],
      "cache": false
    }
  },
  "remoteCache": {
    "enabled": true,
    "signature": true
  }
}
