{
  "extends": "@repo/typescript-config/vite.json",
  "compilerOptions": {
    "tsBuildInfoFile": "./node_modules/.tmp/tsconfig.web.tsbuildinfo",
    "rootDir": ".",
    "types": ["node", "vite/client", "vitest/globals", "@testing-library/jest-dom"],
    "paths": {
      "@/*": ["./src/renderer/src/*"],
      "@/tests/*": ["./tests/*"]
    }
  },
  "include": ["src/renderer/src", "tests"]
}
